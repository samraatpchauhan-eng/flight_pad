{
    "keyboard_name": "flight_pad",
    "manufacturer": "Samraat Chauhan",
    "maintainer": "samraatpchauhan-eng",
    "processor": "RP2040",
    "bootloader": "rp2040",
    "diode_direction": "COL2ROW",
    "url": "https://github.com/qmk/qmk_firmware",
    "features": {
        "bootmagic": true,
        "extrakey": true,
        "mousekey": true,
        "nkro": true,
        "encoder": true
    },
    "matrix_pins": {
        "cols": ["GP26", "GP28", "GP27"],
        "rows": ["GP7", "GP6", "GP29", "GP3"]
    },
    "encoder": {
        "rotary": [
            {"pin_a": "GP0", "pin_b": "GP1", "resolution": 4},
            {"pin_a": "GP2", "pin_b": "GP4", "resolution": 4}
        ]
    },
    "usb": {
        "device_version": "1.0.0",
        "pid": "0x0000",
        "vid": "0xFEED"
    },
    "layouts": {
        "LAYOUT_ortho_3x4": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                {"matrix": [0, 1], "x": 1, "y": 0},
                {"matrix": [0, 2], "x": 2, "y": 0},
                {"matrix": [1, 0], "x": 0, "y": 1},
                {"matrix": [1, 1], "x": 1, "y": 1},
                {"matrix": [1, 2], "x": 2, "y": 1},
                {"matrix": [2, 0], "x": 0, "y": 2},
                {"matrix": [2, 1], "x": 1, "y": 2},
                {"matrix": [2, 2], "x": 2, "y": 2},
                
                {"matrix": [3, 0], "x": 0, "y": 3}
            ]
        }
    }
}